# ── Frontend (Vite) — vai para .env.local ──────────────────────────
# Usadas no client (src/lib/supabase.ts, WPSpeedAudit, etc.)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=

# ── Edge Functions (Supabase) — configurar via dashboard/CLI, não .env ──
# Listadas aqui só para documentação; cada função lê via Deno.env.get().
#
# Todas as funções:
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
#
# strava-sync / strava-auth-url:
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=
# TOKEN_ENCRYPTION_KEY=          # chave AES para cifrar tokens OAuth no banco
#
# Integração Google Calendar:
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
#
# Integração GitHub:
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
#
# Integração Open Finance (Pluggy):
# PLUGGY_CLIENT_ID=
# PLUGGY_CLIENT_SECRET=
#
# mos-chat (assistente de IA):
# ANTHROPIC_API_KEY=
#
# send-support (envio de mensagens de suporte por e-mail):
# RESEND_API_KEY=
#
# sistemas/wp-speed-audit (pagespeed-proxy):
# GOOGLE_PAGESPEED_API_KEY=
#
# admin/deploy tooling:
# VERCEL_TOKEN=
